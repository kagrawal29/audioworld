{
  "display_information": {
    "name": "Charlie",
    "description": "Slack bridge for AudioWorld LinkedIn outreach"
  },
  "features": {
    "bot_user": {
      "display_name": "Charlie",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:history",
        "groups:history",
        "im:history",
        "app_mentions:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "is_hosted": false,
    "token_rotation_enabled": false
  }
}
